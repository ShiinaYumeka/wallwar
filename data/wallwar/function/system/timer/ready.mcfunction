
title @a title {"translate":"做好准备","bold":true}
execute if score GAME_PRO time matches 1 run title @a subtitle {"translate":"天空之壁将于5秒后解除封印","color":"dark_red"}
execute if score GAME_PRO time matches 2..3 run title @a subtitle {"translate":"世界边界将于5秒后缩小","color":"dark_red"}
execute if score GAME_PRO time matches 4 run title @a subtitle {"translate":"死斗模式将于5秒后开始","color":"dark_red"}